{
  "name": "zapchat",
  "version": "2.0.0",
  "description": "ZapChat — WhatsApp-like E2EE Messaging Platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "npm run install:all",
    "install:all": "cd client && npm install && cd ../backend && npm install",
    "build": "cd client && npm run build",
    "start": "cd backend && node server.js",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd client && npm run dev\"",
    "lint": "cd client && npm run lint",
    "db:migrate": "cd backend && node src/scripts/migrate.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}